# Copy to supabase/.env.local (gitignored) and fill in TEST-mode values for local
# `supabase functions serve`. In deployed environments these are set via
# `supabase secrets set` instead — do NOT commit real keys.
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY / SUPABASE_ANON_KEY are auto-injected
# in deployed functions, so you only need them here for local serving.

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RESEND_API_KEY=re_...
